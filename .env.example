# HotpotQA-MAS environment variables
# Copy this to .env and fill in your values:
#   cp .env.example .env

# HuggingFace Hub token (for gated models like Qwen)
# HF_TOKEN=hf_your_token_here
# HUGGINGFACE_HUB_TOKEN=hf_your_token_here

# Dry-run mode: 1 = skip model loading, validate data/config only
# HOTPOTQA_DRY_RUN=0

# Wandb
# WANDB_API_KEY=your_key_here
